# =====================
# OpenClaw Docker 基础参数
# =====================
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONFIG_DIR=./data
OPENCLAW_WORKSPACE_DIR=./data/workspace
OPENCLAW_TZ=Asia/Shanghai

# =====================
# Gateway 暴露与鉴权
# =====================
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# 强烈建议替换为 32 位以上随机字符串
OPENCLAW_GATEWAY_TOKEN=xxxxxxxxxxxxxxxxx

# 仅在你明确知道风险时设置为 1
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# 若要在容器内调用 Docker，可设置宿主机 docker 组 gid
DOCKER_GID=999

# =====================
# 模型提供方凭据（按需填写）
# =====================
DEEPSEEK_API_KEY=xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# =====================
# 渠道接入凭据（按需填写）
# =====================
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# =====================
# Claude Web/AI 凭据（按需填写）
# =====================
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
